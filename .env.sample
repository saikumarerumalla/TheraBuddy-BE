# Application Settings
APP_NAME=TheraBuddy
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# API Configuration
API_V1_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_therapy
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Security Configuration
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption Key
ENCRYPTION_KEY=encryptionkey1234567890abcd

# LLM Provider Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM Settings
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Crisis Detection Keywords
CRISIS_KEYWORDS_JA=["自殺", "死にたい", "消えたい", "終わりにしたい", "生きる価値がない", "死ぬ", "自傷"]
CRISIS_KEYWORDS_EN=["suicide", "kill myself", "end my life", "want to die", "no reason to live", "harm myself", "self-harm"]

# Monitoring
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=["*"]

# File Upload
MAX_UPLOAD_SIZE=5242880
